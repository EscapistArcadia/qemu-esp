        ESP_ACCELERATOR_MMIO_WRITE_VERBOSE(AMU_INFO_NPRIO_REG_3, data, size)
        ESP_ACCELERATOR_MMIO_WRITE_VERBOSE(AMU_INFO_VLD_CTXT_REG, data, size)
        ESP_ACCELERATOR_MMIO_WRITE_VERBOSE(AMU_INFO_SCHED_PERIOD_REG, data, size)
        default:
            printf("[QEMU] MMIO WRITE 0x%08"HWADDR_PRIx" (UNKNOWN) = 0x%016"PRIx64"\n", addr, data);
            break;
    }
}

#undef ESP_ACCELERATOR_MMIO_READ_VERBOSE
#undef ESP_ACCELERATOR_MMIO_WRITE_VERBOSE
