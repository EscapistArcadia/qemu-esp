#define ESP_ACCELERATOR_MMIO_READ_VERBOSE(name, size) \
    case name: \
        printf("[QEMU] MMIO READ 0x%08"HWADDR_PRIx" (%s)\n", addr, #name); \
        break;

#define ESP_ACCELERATOR_MMIO_WRITE_VERBOSE(name, content, size) \
    case name: \
        printf("[QEMU] MMIO WRITE 0x%08"HWADDR_PRIx" (%s) = 0x%016"PRIx64"\n", addr, #name, content); \
        break;

static void esp_accelerator_mmio_read_verbose(hwaddr addr, unsigned size) {
    switch (addr) {
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(CMD_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(STATUS_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(SELECT_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(DEVID_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(PT_ADDRESS_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(PT_NCHUNK_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(PT_SHIFT_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(PT_NCHUNK_MAX_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(PT_ADDRESS_EXTENDED_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(PT_COHERENCE_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(P2P_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(YX_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(SRC_OFFSET_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(DST_OFFSET_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(SPANDEX_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(VALID_CONTEXTS_ACK_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(PT_ADDRESS_REG_0, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(PT_ADDRESS_REG_1, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(PT_ADDRESS_REG_2, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(PT_ADDRESS_REG_3, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(MON_UTIL_REG_0_LO, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(MON_UTIL_REG_0_HI, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(MON_UTIL_REG_1_LO, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(MON_UTIL_REG_1_HI, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(MON_UTIL_REG_2_LO, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(MON_UTIL_REG_2_HI, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(MON_UTIL_REG_3_LO, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(MON_UTIL_REG_3_HI, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(AMU_INFO_QUEUE_PTR_REG_0, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(AMU_INFO_QUEUE_PTR_REG_1, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(AMU_INFO_QUEUE_PTR_REG_2, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(AMU_INFO_NPRIO_REG_3, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(AMU_INFO_VLD_CTXT_REG, size)
        ESP_ACCELERATOR_MMIO_READ_VERBOSE(AMU_INFO_SCHED_PERIOD_REG, size)
        default:
            printf("[QEMU] MMIO READ 0x%08"HWADDR_PRIx" (UNKNOWN)\n", addr);
            break;
    }
}

static void esp_accelerator_mmio_write_verbose(hwaddr addr, uint64_t data, unsigned size) {
    switch (addr) {
        ESP_ACCELERATOR_MMIO_WRITE_VERBOSE(CMD_REG, data, size)
