        ESP_ACCELERATOR_MMIO_WRITE_VERBOSE(AMU_INFO_QUEUE_PTR_REG_1, data, size)
        ESP_ACCELERATOR_MMIO_WRITE_VERBOSE(AMU_INFO_QUEUE_PTR_REG_2, data, size)
        ESP_ACCELERATOR_MMIO_WRITE_VERBOSE(AMU_INFO_QUEUE_PTR_REG_3, data, size)
